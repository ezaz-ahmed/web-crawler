{
  "name": "web-crawler",
  "version": "1.0.0",
  "description": "Async web crawler API with AI-powered markdown conversion",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:docker": "tsx watch src/index.ts",
    "dev:docker:worker": "tsx watch src/worker.ts",
    "build": "tsc && echo Build successful",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down"
  },
  "keywords": [
    "web-crawler",
    "api",
    "fastify",
    "bullmq",
    "openai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "bullmq": "^5.12.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^4.4.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "mammoth": "^1.8.0",
    "nanoid": "^5.0.7",
    "openai": "^4.53.0",
    "p-queue": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.59.1",
    "puppeteer": "^24.43.0",
    "robots-parser": "^3.0.1",
    "@types/node": "^20.19.39",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.5.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.16.2"
  }
}